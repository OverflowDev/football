{
  "name": "fpi-football-market",
  "version": "1.0.0",
  "private": true,
  "description": "Football Performance Index (FPI) - a stock market for football players with AI analytics, live pricing, and on-chain trading on Base.",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:contracts": "hardhat test",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:studio": "prisma studio",
    "hardhat:compile": "hardhat compile",
    "hardhat:deploy:arc": "hardhat run scripts/deploy.js --network arcTestnet",
    "hardhat:deploy:arc-mainnet": "hardhat run scripts/deploy.js --network arc",
    "fund:market": "hardhat run scripts/fund-market.js --network arcTestnet",
    "deploy:futures": "hardhat run scripts/deploy-futures.js --network arcTestnet",
    "fund:futures": "hardhat run scripts/fund-futures.js --network arcTestnet",
    "deploy:ipo": "hardhat run scripts/deploy-ipo.js --network arcTestnet",
    "add:ipo": "hardhat run scripts/add-ipo.js --network arcTestnet",
    "hardhat:verify:arc": "hardhat verify --network arcTestnet",
    "hardhat:deploy:sepolia": "hardhat run scripts/deploy.js --network baseSepolia",
    "hardhat:deploy:base": "hardhat run scripts/deploy.js --network base"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@rainbow-me/rainbowkit": "^2.2.1",
    "@tanstack/react-query": "^5.62.7",
    "@upstash/redis": "^1.34.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^11.15.0",
    "lightweight-charts": "^4.2.2",
    "lucide-react": "^0.468.0",
    "next": "14.2.18",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.13.3",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "tailwind-merge": "^2.5.5",
    "viem": "^2.21.54",
    "wagmi": "^2.13.3",
    "zod": "^3.24.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@openzeppelin/contracts": "^5.1.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.16",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "dotenv": "^16.4.7",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.18",
    "hardhat": "^2.22.17",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
