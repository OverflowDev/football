// FPI — Football Performance Index
// Prisma schema. Datasource is PostgreSQL (Railway/Supabase/local).
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────── Enums ───────────────────────────────

enum Position {
  GK
  DEF
  MID
  FWD
}

enum TransactionType {
  BUY
  SELL
}

enum NotificationType {
  PRICE_ALERT
  TRANSFER_NEWS
  AI_INSIGHT
  DIVIDEND
  TRADE_EXECUTED
}

enum AgentType {
  SCOUT
  VALUATION
  PORTFOLIO
  NEWS
}

enum AlertDirection {
  ABOVE
  BELOW
}

enum NewsSentiment {
  BULLISH
  BEARISH
  NEUTRAL
}

// ─────────────────────── NextAuth core models ────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────── User ────────────────────────────────

model User {
  id               String    @id @default(cuid())
  email            String?   @unique
  name             String?
  username         String?   @unique
  image            String?
  emailVerified    DateTime?
  walletAddress    String?   @unique
  virtualBalance   Decimal   @default(10000.00) @db.Decimal(18, 2)
  isPremium        Boolean   @default(false)
  premiumExpiresAt DateTime?
  stripeCustomerId String?   @unique
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  portfolio     Portfolio[]
  transactions  Transaction[]
  watchList     WatchList[]
  notifications Notification[]
  aiChats       AIChat[]
  priceAlerts   PriceAlert[]
}

// ─────────────────────────────── Club ────────────────────────────────

model Club {
  id        String   @id @default(cuid())
  name      String
  shortName String
  logo      String?
  league    String
  country   String
  players   Player[]
}

// ────────────────────────────── Player ───────────────────────────────

model Player {
  id                    String   @id @default(cuid())
  apiFootballId         Int      @unique
  name                  String
  slug                  String   @unique
  position              Position
  nationality           String
  age                   Int
  clubId                String
  currentPrice          Decimal  @default(0) @db.Decimal(18, 2)
  previousPrice         Decimal  @default(0) @db.Decimal(18, 2)
  priceChange24h        Decimal  @default(0) @db.Decimal(18, 2)
  priceChangePercent24h Decimal  @default(0) @db.Decimal(10, 4)
  marketCap             Decimal  @default(0) @db.Decimal(24, 2)
  totalShares           Int      @default(10000000)
  sharesAvailable       Int      @default(10000000)
  // FPI inputs (see lib/pricing-engine.ts)
  baseValue             Decimal  @default(50) @db.Decimal(18, 2)
  formRating            Decimal  @default(50) @db.Decimal(6, 2)
  rumorScore            Decimal  @default(0) @db.Decimal(6, 2)
  injuryStatus          Boolean  @default(false)
  performanceIndex      Decimal  @default(50) @db.Decimal(6, 2)
  imageUrl              String?
  contractAddress       String?
  tokenId               Int?
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  club         Club           @relation(fields: [clubId], references: [id])
  priceHistory PriceHistory[]
  portfolio    Portfolio[]
  transactions Transaction[]
  stats        PlayerStats[]
  news         NewsItem[]
  watchList    WatchList[]
  notifications Notification[]
  priceAlerts  PriceAlert[]

  @@index([position])
  @@index([clubId])
  @@index([isActive])
}

// ────────────────────────── PlayerStats ──────────────────────────────

model PlayerStats {
  id            String   @id @default(cuid())
  playerId      String
  season        String
  matches       Int      @default(0)
  goals         Int      @default(0)
  assists       Int      @default(0)
  minutesPlayed Int      @default(0)
  yellowCards   Int      @default(0)
  redCards      Int      @default(0)
  rating        Decimal  @default(0) @db.Decimal(4, 2)
  form          Decimal  @default(0) @db.Decimal(4, 2)
  updatedAt     DateTime @updatedAt

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, season])
}

// ────────────────────────── PriceHistory ─────────────────────────────

model PriceHistory {
  id            String   @id @default(cuid())
  playerId      String
  price         Decimal  @db.Decimal(18, 2)
  volume        Int      @default(0)
  triggerReason String?
  timestamp     DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId, timestamp])
}

// ─────────────────────────── Portfolio ───────────────────────────────

model Portfolio {
  id              String   @id @default(cuid())
  userId          String
  playerId        String
  shares          Int      @default(0)
  averageBuyPrice Decimal  @default(0) @db.Decimal(18, 2)
  totalInvested   Decimal  @default(0) @db.Decimal(18, 2)
  updatedAt       DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([userId, playerId])
  @@index([userId])
}

// ────────────────────────── Transaction ──────────────────────────────

model Transaction {
  id            String          @id @default(cuid())
  userId        String
  playerId      String
  type          TransactionType
  shares        Int
  pricePerShare Decimal         @db.Decimal(18, 2)
  totalAmount   Decimal         @db.Decimal(18, 2)
  fee           Decimal         @db.Decimal(18, 2)
  isOnChain     Boolean         @default(false)
  txHash        String?
  createdAt     DateTime        @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([playerId, createdAt])
}

// ─────────────────────────── WatchList ───────────────────────────────

model WatchList {
  id       String   @id @default(cuid())
  userId   String
  playerId String
  addedAt  DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([userId, playerId])
}

// ────────────────────────── Notification ─────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  playerId  String?
  createdAt DateTime         @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  player Player? @relation(fields: [playerId], references: [id], onDelete: SetNull)

  @@index([userId, isRead])
}

// ─────────────────────────────── AIChat ──────────────────────────────

model AIChat {
  id        String    @id @default(cuid())
  userId    String
  messages  Json
  agent     AgentType
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, agent])
}

// ────────────────────────── PriceAlert ───────────────────────────────

model PriceAlert {
  id          String         @id @default(cuid())
  userId      String
  playerId    String
  targetPrice Decimal        @db.Decimal(18, 2)
  direction   AlertDirection
  isTriggered Boolean        @default(false)
  createdAt   DateTime       @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─────────────────────────────── NewsItem ────────────────────────────

model NewsItem {
  id              String        @id @default(cuid())
  playerId        String?
  headline        String
  summary         String        @db.Text
  source          String?
  url             String?
  sentiment       NewsSentiment @default(NEUTRAL)
  sentimentScore  Float         @default(0)
  priceImpact     Float         @default(0)
  publishedAt     DateTime      @default(now())
  createdAt       DateTime      @default(now())

  player Player? @relation(fields: [playerId], references: [id], onDelete: SetNull)

  @@index([playerId, publishedAt])
}
