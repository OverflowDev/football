# ─────────────────────────────────────────────────────────────
# FPI — Football Performance Index : environment variables
# Copy to `.env` and fill in. The app runs in DEMO mode (mock data) with
# zero config. Identity is your connected wallet — no email/password login.
# ─────────────────────────────────────────────────────────────

# --- Database (Supabase / Railway / Neon / local Postgres) ---
# Optional. Without it the app uses an in-memory demo account.
DATABASE_URL="postgresql://user:password@localhost:5432/fpi?schema=public"

# --- Redis (Upstash) — OPTIONAL caching, safe to leave blank ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- AI (OpenAI) — OPTIONAL; agents stream a grounded demo response without it ---
OPENAI_API_KEY=
OPENAI_MODEL="gpt-4o"

# --- Football data — OPTIONAL; mock stats/news are used without these ---
API_FOOTBALL_KEY=
NEWS_API_KEY=

# --- Auth (SIWE wallet sign-in) ---
# Required in production. Signs the httpOnly session cookie.
SESSION_SECRET=

# --- Web3 / wallet ---
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# --- Arc network (primary launch chain; USDC is the native gas token) ---
# Testnet defaults shown; mainnet not yet public.
NEXT_PUBLIC_ARC_RPC_URL="https://rpc.testnet.arc.network"
ARC_TESTNET_RPC_URL="https://rpc.testnet.arc.network"
# ARC_RPC_URL=            # set when Arc mainnet is live
# ARC_CHAIN_ID=           # set when Arc mainnet is live
# Native USDC system contract on Arc testnet (6-decimal ERC-20 interface):
NEXT_PUBLIC_USDC_ADDRESS="0x3600000000000000000000000000000000000000"
NEXT_PUBLIC_FOOTBALL_MARKET_ADDRESS=
NEXT_PUBLIC_PRICE_ORACLE_ADDRESS=

# --- Smart contract deployment + oracle ---
PRIVATE_KEY=          # deployer key (holds testnet USDC for gas)
ORACLE_PRIVATE_KEY=   # backend signer that pushes price updates on-chain

# --- Cron security ---
CRON_SECRET=

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SOCKET_URL="http://localhost:3001"
SOCKET_PORT=3001
